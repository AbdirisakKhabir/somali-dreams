# MAMP: default MySQL port is 8889 (not 3306). Use TCP or socket:
# TCP:   mysql://root:root@localhost:8889/somalidreams
# Socket: mysql://root:root@localhost:3306/somalidreams?socket=/Applications/MAMP/tmp/mysql/mysql.sock
DATABASE_URL="mysql://user:password@localhost:3306/somalidreams"
JWT_SECRET_KEY=your-secret-key

# Bawa.app WhatsApp API (for Somali Dreams notifications)
BAWA_TOKEN=your-bawa-token
BAWA_INSTANCE_ID=your-bawa-instance-id

# Somali Dreams website
SOMALI_DREAMS_MEMBERS_URL=https://somalidreams.com/members
# Pay page URL - used for referral links in WhatsApp (friends click to register)
# Local: http://localhost:3000/pay
# Production: https://yoursite.com/pay
SOMALI_DREAMS_PAY_URL=https://somalidreams.com/pay

# Base URL for server-side callbacks (WhatsApp, etc.) - required when deployed
NEXTAUTH_URL=https://somalidreams.com
# Or use SITE_URL as fallback

# E-Dahab Payment API (https://edahab.net)
# Hash = SHA256(JSON body + secret)
EDAHAB_API_KEY=your-api-key
EDAHAB_SECRET=your-secret-key
EDAHAB_AGENT_CODE=your-agent-code
EDAHAB_AMOUNT=500
EDAHAB_CURRENCY=SLSH
# E-Dahab does NOT redirect to our app after payment. Use one of:
# 1. Admin: Members page → "Process pending payments" button
# 2. Cron: GET /api/cron/process-pending-payments (Bearer CRON_SECRET) every 5 min
EDAHAB_RETURN_URL=https://app.somalidreams.com/pay/return

# Payment page (public, for client-side)
NEXT_PUBLIC_MEMBERS_AREA_URL=https://somalidreams.com/members

# Cron: daily membership expiry (set status to Pending when endDate passed)
# Vercel cron sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-cron-secret
